{
  "name": "@momo/template-generator",
  "version": "0.1.0",
  "description": "Dynamic template generation engine for Momo",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts",
    "lint": "oxlint .",
    "test": "vitest run"
  },
  "dependencies": {
    "fs-extra": "^11.3.0",
    "handlebars": "^4.7.8",
    "tinyglobby": "^0.2.11"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.13.5",
    "tsup": "^8.3.5",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8"
  }
}
